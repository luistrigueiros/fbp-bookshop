{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": "src",
        "composite": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "paths": {
            "@/*": ["./src/*"],
            "library-data-layer": [
                "../library-data-layer/dist/index.d.ts"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "test/**/*"
    ]
}
