{
    "name": "library-app",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/index.js",
    "types": "src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "typecheck": "bunx tsc --noEmit",
        "preconfig": "bun ../../scripts/config.ts && bun scripts/bundle-migrations.ts",
        "dev": "bun run preconfig && bunx wrangler dev --var ENVIRONMENT:development",
        "deploy": "bun run build && bun run preconfig && bunx wrangler deploy --minify",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "build:frontend": "bunx vite build",
        "build:worker": "bun build src/index.ts --target=browser --outfile=dist/index.js --external @cloudflare/workers-types",
        "build": "rm -rf dist && bun run build:types && bun run build:frontend && bun run build:worker",
        "build:types": "bunx tsc --project tsconfig.build.json --emitDeclarationOnly",
        "test": "bun test",
        "lint": "bunx eslint . --ext .ts",
        "lint:fix": "bunx eslint . --ext .ts --fix"
    },
    "dependencies": {
        "dotenv": "catalog:",
        "hono": "^4.12.5",
        "@logtape/logtape": "^2.0.4",
        "@logtape/hono": "^2.0.4",
        "@trpc/server": "^10.45.2",
        "@trpc/client": "^10.45.2",
        "zod": "^3.23.8",
        "solid-js": "^1.9.3",
        "@solidjs/router": "^0.15.2",
        "library-data-layer": "workspace:*"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260307.1",
        "@types/bun": "^1.3.10",
        "miniflare": "^4.20260305.0",
        "wrangler": "^4.71.0",
        "vite": "^6.1.1",
        "vite-plugin-solid": "^2.11.10",
        "library-test-utils": "workspace:*"
    }
}