{
  "name": "library-excel-export",
  "version": "1.0.0",
  "description": "Excel export service for Library book shop using Cloudflare Workers, Queues, and Durable Objects",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "config": "bun ../../scripts/config.ts",
    "dev": "wrangler dev",
    "deploy": "bun run build && bun run config && bunx wrangler deploy --minify",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./test/setup.ts",
    "lint": "bunx eslint ."
  },
  "dependencies": {
    "@logtape/hono": "^2.0.4",
    "@types/node": "catalog:",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "hono": "^4.12.7",
    "library-data-layer": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/bun": "catalog:",
    "library-test-utils": "workspace:*",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
