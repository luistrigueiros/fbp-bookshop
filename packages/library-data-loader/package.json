{
    "name": "library-data-loader",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/index.js",
    "types": "src/index.ts",
    "scripts": {
        "typecheck": "bunx tsc --noEmit",
        "preconfig": "bun ../../scripts/config.ts",
        "dev": "bun run preconfig && bunx wrangler dev",
        "deploy": "bun run preconfig && bunx wrangler deploy --minify",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "build": "rm -rf dist && bun run build:types && bun build src/index.ts --target=browser --outfile=dist/index.js --external @cloudflare/workers-types",
        "build:types": "bunx tsc --project tsconfig.build.json --emitDeclarationOnly",
        "test": "bun test",
        "lint": "bunx eslint . --ext .ts",
        "lint:fix": "bunx eslint . --ext .ts --fix"
    },
    "dependencies": {
        "dotenv": "catalog:",
        "hono": "catalog:",
        "library-excel-extractor": "workspace:*",
        "library-data-layer": "workspace:*"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "catalog:",
        "@types/bun": "catalog:",
        "miniflare": "catalog:",
        "wrangler": "catalog:",
        "drizzle-kit": "catalog:"
    }
}