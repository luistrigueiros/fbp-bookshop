{
  "name": "library-cli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "library-load": "./src/index.ts"
  },
  "dependencies": {
    "library-app": "workspace:*",
    "library-trpc": "workspace:*",
    "library-excel-extractor": "workspace:*",
    "@trpc/client": "catalog:",
    "zod": "catalog:",
    "commander": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --minify --sourcemap",
    "lint": "bunx eslint .",
    "upload:data:remote": "bun run src/index.ts -u https://library-app-worker.luistrigueiros.workers.dev/api FBP-DB2.xlsx",
    "upload:data:local": "bun run src/index.ts -u http://localhost:8787/api FBP-DB2.xlsx"
  }
}
