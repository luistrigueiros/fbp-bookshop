{
    "name": "library-excel-extractor",
    "version": "1.0.0",
    "description": "Extract Books, Genders, and Publishers from FBP-DB.xlsx",
    "type": "module",
    "main": "dist/index.js",
    "types": "src/index.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "rm -rf dist && bun run build:types && bun build ./src/index.ts --outdir ./dist --target bun --sourcemap=external",
        "build:types": "bunx tsc --project tsconfig.build.json --emitDeclarationOnly",
        "typecheck": "bunx tsc --noEmit",
        "test": "bun test",
        "lint": "bunx eslint .",
        "postinstall": "bun run build"
    },
    "keywords": [
        "excel",
        "xlsx",
        "extractor",
        "books",
        "library"
    ],
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "catalog:",
        "@types/bun": "catalog:",
        "@typescript-eslint/eslint-plugin": "catalog:",
        "@typescript-eslint/parser": "catalog:",
        "eslint": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:"
    },
    "dependencies": {
        "xlsx": "catalog:"
    }
}